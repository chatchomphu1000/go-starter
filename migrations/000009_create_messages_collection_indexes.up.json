{
  "createIndexes": "messages",
  "indexes": [
    { "key": { "thread_id": 1 }, "name": "thread_id" },
    { "key": { "thread_id": 1, "created_at": 1 }, "name": "thread_created" },
    { "key": { "sender_id": 1 }, "name": "sender_id" },
    { "key": { "thread_id": 1, "read_by": 1 }, "name": "thread_read_by" },
    { "key": { "created_at": -1 }, "name": "created_at_desc" }
  ]
}
